# ============================================
# Aji OS Backend Configuration
# ============================================

# AI Provider Configuration
# ============================================

# Groq API Key (Primary Provider)
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Ollama Configuration (for local/offline use)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Default Provider Selection
DEFAULT_PROVIDER=groq
DEFAULT_MODEL=mixtral-8x7b-32768

# ============================================
# Server Configuration
# ============================================

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173

# ============================================
# Logging Configuration
# ============================================

LOG_LEVEL=INFO
LOG_FILE=logs/aji.log

# ============================================
# Database Configuration
# ============================================

DATABASE_URL=sqlite:///./data/conversations.db

# ============================================
# AI Model Settings
# ============================================

# Model Temperature (0.0 = deterministic, 1.0 = creative)
AI_TEMPERATURE=0.7

# Maximum tokens for responses
AI_MAX_TOKENS=2048

# System prompt for AI
AI_SYSTEM_PROMPT=You are Aji OS, a helpful and intelligent desktop assistant. You help users with their tasks, answer questions, and control their computer. Be concise, friendly, and efficient.

# ============================================
# Voice Configuration
# ============================================

# Text-to-Speech
TTS_ENGINE=pyttsx3
TTS_VOICE_RATE=150

# Speech Recognition
SPEECH_RECOGNITION_LANGUAGE=en-US
SPEECH_RECOGNITION_TIMEOUT=5

# ============================================
# Feature Flags
# ============================================

ENABLE_VOICE=true
ENABLE_PLUGINS=true
ENABLE_HISTORY=true
ENABLE_SHORTCUTS=true

# ============================================
# Security
# ============================================

# CORS allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ============================================
# Development Settings
# ============================================

DEBUG=false
RELOAD_ON_CHANGE=true
