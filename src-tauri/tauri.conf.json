{
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:5173",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Aji OS",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "package": {
    "productName": "Aji OS",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "execute": true,
        "open": true
      },
      "process": {
        "all": false,
        "exit": true
      },
      "fs": {
        "all": false,
        "readDir": true,
        "readFile": true,
        "writeFile": true,
        "createDir": true
      },
      "window": {
        "all": true
      },
      "http": {
        "all": true
      }
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Aji OS - AI Desktop Assistant",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false
      }
    ],
    "bundle": {
      "active": true,
      "targets": [
        "msi",
        "nsis",
        "dmg",
        "deb"
      ],
      "identifier": "com.aijos.app",
      "icon": [
        "../../assets/icon.png",
        "../../assets/icon.ico"
      ]
    }
  }
}
